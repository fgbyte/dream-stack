{
  "name": "dream-stack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260317.1",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.7",
      "@orpc/openapi": "^1.13.7",
      "@orpc/zod": "^1.13.7",
      "better-auth": "^1.5.5",
      "alchemy": "^0.82.1",
      "vitest": "^3.1.1",
      "@vitest/ui": "^3.1.1",
      "@vitest/coverage-v8": "^3.1.1",
      "jsdom": "^26.0.0",
      "@libsql/client": "^0.17.0",
      "libsql": "0.5.22",
      "@orpc/client": "^1.13.7"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @dream-stack/db db:push",
    "db:studio": "turbo -F @dream-stack/db db:studio",
    "db:generate": "turbo -F @dream-stack/db db:generate",
    "db:migrate": "turbo -F @dream-stack/db db:migrate",
    "db:local": "turbo -F @dream-stack/db db:local",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@dream-stack/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@dream-stack/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.34.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
